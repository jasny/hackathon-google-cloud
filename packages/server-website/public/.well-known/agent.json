{
  "name": "De Staatsman",
  "description": "Agent for the Dutch political party De Staatsman. Provides information about the party, policy positions and supporter registration.",
  "version": "1.0.0",
  "provider": {
    "organization": "De Staatsman"
  },
  "authentication": {
    "type": "none"
  },
  "endpoints": {
    "messages": "http://localhost:3000/a2a/messages",
    "tasks": "http://localhost:3000/a2a/tasks",
    "artifacts": "http://localhost:3000/a2a/artifacts"
  },
  "capabilities": [
    {
      "name": "hello",
      "description": "Connect the organization with the user. Requests specific user data for personalization and regional information."
    },
    {
      "name": "membership_application",
      "description": "Submit an application to become a member of De Staatsman.",
      "input_schema": {
        "type": "object",
        "properties": {
          "full_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "date_of_birth": {
            "type": "string",
            "format": "date"
          },
          "gender": {
            "type": "string",
            "enum": [
              "Prefer not to say",
              "Male",
              "Female",
              "Other"
            ]
          },
          "street_name": {
            "type": "string"
          },
          "house_number": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "city": {
            "type": "string"
          }
        }
      }
    }
  ]
}
